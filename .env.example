# ============================================================
# OpenClaw VK Plugin — Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env
# ============================================================

# ============================================================
# MODULE 1: VK Bot (REQUIRED)
# ============================================================

# VK community token — get it in: vk.com/editapp?act=tokens (or community settings → API)
# Guide: docs/VK_TOKENS_GUIDE_RU.md
VK_COMMUNITY_TOKEN=your_vk_community_token_here

# VK community ID (number, without minus sign)
VK_COMMUNITY_ID=123456789

# ============================================================
# MODULE 2: LLM Proxy (groq-proxy)
# Needed if you want to use AI responses via Groq / OpenRouter
# ============================================================

# Groq API keys — get free keys at: https://console.groq.com
# Free tier: 1 request per 62 seconds per key. Add up to 20 keys for higher throughput.
GROQ_KEY_1=gsk_your_groq_key_here
# GROQ_KEY_2=gsk_second_key_if_you_have_one
# GROQ_KEY_3=
# GROQ_KEY_4=

# Groq model to use (default: llama-3.3-70b-versatile)
# Other options: llama3-8b-8192, llama3-70b-8192, mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter API keys — get free keys at: https://openrouter.ai/keys
# Free models: qwen/qwen3.6-plus:free, google/gemma-2-9b-it:free, etc.
OPENROUTER_KEY_1=sk-or-v1-your_openrouter_key_here
# OPENROUTER_KEY_2=
# OPENROUTER_KEY_3=

# OpenRouter model to use (default: qwen/qwen3.6-plus:free)
OPENROUTER_MODEL=qwen/qwen3.6-plus:free

# LLM Proxy port (default: 8787)
GROQ_PROXY_PORT=8787

# OPTIONAL: SOCKS5 proxy (only needed if LLM APIs are blocked in your region)
# Format: socks5h://username:password@host:port
# SOCKS_PROXY=socks5h://user:pass@your-proxy-host:1080

# ============================================================
# MODULE 3: Великий Мудрец / Multi-LLM Analyst
# Needs Cerebras API for synthesis (free tier available)
# ============================================================

# Cerebras API key — get free key at: https://cloud.cerebras.ai
# Free tier: generous limits, fast inference
CEREBRAS_KEY=csk-your_cerebras_key_here

# Cerebras model (default: llama3.1-8b)
# Other options: llama3.1-70b
CEREBRAS_MODEL=llama3.1-8b

# ============================================================
# MODULE 4: Image Generation (skills/image-gen)
# ============================================================

# ModelsLab API key — get free key at: https://modelslab.com
# Free tier: 100 images/day
MODELSLAB_KEY=your_modelslab_key_here

# ============================================================
# SERVER PATHS (adjust to your installation directory)
# ============================================================

# Where OpenClaw is installed on the server
OPENCLAW_DIR=/opt/openclaw-vk-plugin

# Where browser-bridge scripts are located
BRIDGE_DIR=/opt/browser-bridge

# Where Sage stores sessions and reports
SAGE_DATA_DIR=/opt/openclaw-sage

# ============================================================
# OPTIONAL: SOCKS5 proxy for browser bridge
# Only needed if you route browser sessions through a proxy
# ============================================================
# BROWSER_PROXY=socks5://your-proxy-host:1080
